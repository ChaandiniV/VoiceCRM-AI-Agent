APP_ENV=local
DATABASE_PATH=data/voicecrm.db

# Direct CRM mode. Keep mock unless you want FastAPI to call HubSpot directly.
CRM_PROVIDER=mock
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_BASE_URL=https://api.hubapi.com

# Public URL used by Twilio webhooks if you test with ngrok.
PUBLIC_BASE_URL=http://127.0.0.1:8000
BUSINESS_NAME=Demo Business

# Make.com integration. Paste your Make Custom Webhook URL here.
# Leave empty to run local mock mode with no accounts/no paid API.
MAKE_WEBHOOK_URL=
MAKE_WEBHOOK_SECRET=demo-secret-change-me

# Optional real AI qualification through Hugging Face Inference Providers
AI_PROVIDER=rules
HF_TOKEN=
HF_MODEL=openai/gpt-oss-120b:fastest
HF_BASE_URL=https://router.huggingface.co/v1
